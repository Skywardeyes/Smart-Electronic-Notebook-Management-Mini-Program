page {
  background-color: #f5f5f5;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.6;
}

.page-container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx;
  background-color: #f5f5f5;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.page-subtitle {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #666666;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  color: #333333;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.btn-primary {
  background-color: #5b8c5a;
  color: #ffffff;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background-color: #ffffff;
  color: #5b8c5a;
  border: 1px solid #5b8c5a;
}

.btn-secondary::after {
  border: none;
}

.btn-primary,
.btn-secondary {
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.btn-small {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 30rpx;
  font-size: 24rpx;
}

.btn-group {
  display: flex;
  gap: 20rpx;
}

.ajc {
  display: flex;
  align-items: center;
  justify-content: center;
}

.text-muted {
  color: #999999;
}

.note-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.note-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.note-meta {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.note-snippet {
  font-size: 26rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.fixed-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx 32rpx;
  background: linear-gradient(to top, rgba(245, 245, 245, 0.96), rgba(245, 245, 245, 0.7));
  box-sizing: border-box;
}

.fixed-footer .btn-group {
  width: 100%;
}

.fixed-footer .btn-group button {
  flex: 1;
}

.input-modern {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 1px solid #eeeeee;
  background-color: #ffffff;
  font-size: 28rpx;
}

.input-modern + .input-modern {
  margin-top: 16rpx;
}

.input-modern::placeholder {
  color: #999999;
}

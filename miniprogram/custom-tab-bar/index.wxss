.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid #eaeaea;
  display: flex;
  z-index: 1000;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-text {
  font-size: 24rpx;
  color: #8a8a8a;
}

.tab-item-active .tab-text {
  color: #6c5ce7;
}

.tab-plus {
  transform: translateY(-8rpx);
}

.plus-circle {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #6c5ce7;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(108, 92, 231, 0.35);
}

.plus-open {
  background: #5b4ae0;
}

.plus-text {
  color: #ffffff;
  font-size: 52rpx;
  line-height: 52rpx;
  margin-top: -4rpx;
}

.action-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.16);
  z-index: 999;
}

.action-panel {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: calc(116rpx + env(safe-area-inset-bottom));
  width: 300rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
}

.action-item {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333333;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:last-child {
  border-bottom: none;
}


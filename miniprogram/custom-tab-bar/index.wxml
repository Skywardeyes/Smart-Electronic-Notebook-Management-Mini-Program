<view>
  <view wx:if="{{expandMenu}}" class="action-mask" bindtap="onMaskTap">
    <view class="action-panel" catchtap="onPanelTap">
      <view class="action-item" bindtap="onTapNewNote">新建笔记</view>
      <view class="action-item" bindtap="onTapAI">AI问答</view>
    </view>
  </view>

  <view class="custom-tabbar">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'tab-item-active' : ''}} {{index === 1 ? 'tab-plus' : ''}}"
      data-index="{{index}}"
      bindtap="onTapTab"
    >
      <text wx:if="{{index !== 1}}" class="tab-text">{{item.text}}</text>
      <view wx:else class="plus-circle {{expandMenu ? 'plus-open' : ''}}">
        <text class="plus-text">+</text>
      </view>
    </view>
  </view>
</view>


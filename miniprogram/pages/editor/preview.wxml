<view class="page">
  <view class="page-header">
    <view>
      <view class="page-title">我的云笔记</view>
      <view class="page-subtitle">
        {{dataObj.length || 0}} 条笔记，点击任意条进入详情
      </view>
    </view>
  </view>

  <scroll-view class="scroll-full" scroll-y>
    <block wx:if="{{dataObj && dataObj.length}}">
      <view wx:for="{{dataObj}}" wx:key="{{index}}" data-index="{{index}}" bindtap="toDetail" class="note-card">
        <view class="note-title">{{item.title || '未命名笔记'}}</view>
        <view class="note-meta text-muted">第 {{index + 1}} 条 · 云端保存</view>
        <view class="note-snippet">
          {{item.content || '暂无摘要，点击查看完整内容'}}
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="card ajc empty-state">
        <view>
          <view class="empty-title">还没有任何笔记</view>
          <view class="empty-desc">从首页新建一条，或在这里刷新列表。</view>
        </view>
      </view>
    </block>
  </scroll-view>
</view>

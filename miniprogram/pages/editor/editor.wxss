/* pages/editor/editor.wxss */

.editor-card {
  padding-bottom: 24rpx;
}

.summary-card {
  padding-bottom: 40rpx;
}

.summary-title-row .editor-summary-ai-btn {
  flex-shrink: 0;
}

.summary-hint {
  margin-top: -4rpx;
  margin-bottom: 12rpx;
}

/* 标签行：添加 + 提取标签，紧凑高度与正文字段协调 */
.editor-tag-action-btn {
  flex-shrink: 0;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
}

.editor-summary-ai-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 26rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
}

.editor-summary-textarea {
  width: 100%;
  min-height: 200rpx;
  max-height: 480rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  border: 1px solid #ede9fe;
  background-color: #faf5ff;
  font-size: 26rpx;
  color: #4c1d95;
}

.editor-textarea {
  width: 100%;
  min-height: 400rpx;
  max-height: 900rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  border: 1px solid #eeeeee;
  background-color: #ffffff;
  font-size: 28rpx;
}

.editor-toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 12rpx 0 14rpx;
}

.toolbar-btn {
  min-width: 68rpx;
  padding: 8rpx 14rpx;
  border-radius: 10rpx;
  border: 1px solid #ddd6fe;
  background-color: #f8fafc;
  color: #4c1d95;
  font-size: 22rpx;
  text-align: center;
  line-height: 1.2;
}

.toolbar-btn-active {
  background-color: #ede9fe;
  border-color: #a78bfa;
  color: #5b21b6;
}

.editor-richtext {
  width: 100%;
  min-height: 420rpx;
  padding: 16rpx 18rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  border: 1px solid #eeeeee;
  background-color: #ffffff;
}

.image-manager {
  margin-top: 14rpx;
}

.image-manager-title {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.image-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.image-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #eef2ff;
}

.image-chip-text {
  font-size: 22rpx;
  color: #3730a3;
}

.image-chip-caption {
  font-size: 22rpx;
  color: #475569;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.image-chip-edit {
  font-size: 22rpx;
  color: #2563eb;
}

.image-chip-del {
  font-size: 22rpx;
  color: #dc2626;
}

.tag-row {
  margin-top: 16rpx;
}

.input-modern {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  border: 1px solid #eeeeee;
  background-color: #ffffff;
  font-size: 26rpx;
}

.tag-scroll {
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background-color: #f3e8ff;
  color: #7c3aed;
  font-size: 24rpx;
}

.tag-input-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-input {
  flex: 1;
  min-width: 200rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 1px solid #eeeeee;
  background-color: #ffffff;
  font-size: 26rpx;
}
<view class="page-container">
  <view class="page-header">
    <view>
      <view class="page-title">神仙助</view>
      <view class="page-subtitle">问答、摘要与润色，一站式 AI 小助手</view>
    </view>
  </view>

  <view class="section">
    <view class="card mode-tabs">
      <view class="mode-pill {{mode==='qa' ? 'mode-pill-active' : ''}}" data-mode="qa" bindtap="switchMode">
        问答模式
      </view>
      <view class="mode-pill {{mode==='summary' ? 'mode-pill-active' : ''}}" data-mode="summary" bindtap="switchMode">
        摘要模式
      </view>
      <view class="mode-pill {{mode==='polish' ? 'mode-pill-active' : ''}}" data-mode="polish" bindtap="switchMode">
        扩写模式
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{mode==='qa'}}">
    <view class="card context-row">
      <view class="context-pill {{contextType==='none' ? 'context-pill-active' : ''}}" data-type="none" bindtap="switchContext">
        新对话
      </view>
      <view class="context-pill {{contextType==='all' ? 'context-pill-active' : ''}}" data-type="all" bindtap="switchContext">
        全部笔记
      </view>
      <view class="context-pill {{contextType==='note' ? 'context-pill-active' : ''}}" data-type="note" bindtap="switchContext">
        当前笔记
      </view>
    </view>

    <view class="card">
      <view class="section-title">对话</view>
      <scroll-view class="qa-scroll" scroll-y>
        <block wx:for="{{qaHistory}}" wx:key="{{index}}">
          <view class="qa-item {{item.role === 'user' ? 'qa-user' : 'qa-ai'}}">
            <text>{{item.content}}</text>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>

  <view class="section" wx:if="{{mode!=='qa'}}">
    <view class="card">
      <view class="section-title">
        {{mode==='summary' ? '原文内容' : '需要润色的文本'}}
      </view>
      <textarea class="ai-textarea"
                placeholder="{{mode==='summary' ? '粘贴或输入需要摘要的内容' : '输入需要润色或扩写的内容'}}"
                value="{{inputText}}"
                bindinput="onInput"
                auto-height="true" />
    </view>
    <view class="card" wx:if="{{resultText}}">
      <view class="section-title">
        {{mode==='summary' ? '摘要结果' : '润色结果'}}
      </view>
      <view class="result-text">{{resultText}}</view>
      <button class="btn-secondary btn-small" bindtap="onCopyResult">复制结果</button>
    </view>
  </view>

  <view class="section">
    <view class="card quick-ask-row">
      <view class="quick-ask" data-text="帮我总结这段内容的要点" bindtap="onQuickAsk">帮我总结</view>
      <view class="quick-ask" data-text="提取这段内容的关键词" bindtap="onQuickAsk">提取关键词</view>
      <view class="quick-ask" data-text="请用更通俗的方式解释这段话" bindtap="onQuickAsk">解释概念</view>
      <view class="quick-ask" data-text="请用更正式的书面语润色这段话" bindtap="onQuickAsk">润色文字</view>
    </view>
  </view>

  <view class="fixed-footer">
    <view class="ai-input-row">
      <textarea class="ai-input"
                placeholder="{{mode==='qa' ? '向神仙提问...' : '输入或粘贴内容...'}}"
                value="{{inputText}}"
                bindinput="onInput"
                auto-height="true" />
      <button class="btn-primary btn-small"
              loading="{{loading}}"
              bindtap="onSend">发送</button>
    </view>
  </view>
</view>
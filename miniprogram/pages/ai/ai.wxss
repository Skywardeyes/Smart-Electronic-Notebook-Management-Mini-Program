/* pages/ai/ai.wxss */

.mode-tabs {
  display: flex;
  justify-content: space-between;
}

.mode-pill {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background-color: #f0f0f0;
  font-size: 26rpx;
}

.mode-tabs-two .mode-pill:last-child {
  margin-right: 0;
}

.mode-pill-active {
  background: linear-gradient(135deg, #a855f7, #6366f1);
  color: #ffffff;
}

.context-row {
  display: flex;
}

.context-pill {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  border-radius: 999rpx;
  background-color: #f5f5f5;
  font-size: 24rpx;
}

.context-pill + .context-pill {
  margin-left: 12rpx;
}

.context-pill-active {
  background-color: #f3e8ff;
  color: #7c3aed;
}

.context-row-two .context-pill + .context-pill {
  margin-left: 16rpx;
}

.history-hint {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.45;
  margin-bottom: 16rpx;
}

.history-scroll {
  max-height: 520rpx;
}

.history-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.history-item-trash {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #94a3b8;
  padding: 12rpx 4rpx 12rpx 20rpx;
}

.history-item-icon {
  width: 52rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.history-item-icon-text {
  font-size: 30rpx;
}

.history-item-body {
  flex: 1;
  min-width: 0;
}

.history-item-preview {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.history-item-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.history-empty {
  padding: 48rpx 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #9ca3af;
}

.qa-scroll {
  max-height: 480rpx;
  margin-top: 12rpx;
}

.qa-item {
  padding: 12rpx 16rpx;
  margin-bottom: 8rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.qa-user {
  align-self: flex-start;
  background-color: #f3e8ff;
}

.qa-ai {
  align-self: flex-end;
  background-color: #ffffff;
}

.ai-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 1px solid #eeeeee;
  box-sizing: border-box;
}

.result-text {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.quick-ask-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-ask {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background-color: #f0f0f0;
  font-size: 24rpx;
}

.note-picker-bar {
  width: 100%;
  padding-bottom: 12rpx;
}

.note-picker-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.note-picker-title {
  font-size: 22rpx;
  color: #64748b;
}

.note-picker-ops {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.note-op {
  font-size: 22rpx;
  color: #64748b;
}

.note-op-main {
  color: #7c3aed;
}

.note-picker-list {
  margin-top: 10rpx;
  max-height: 260rpx;
  overflow: hidden;
  border: 1px solid #f0f0f0;
  border-radius: 12rpx;
  background: #ffffff;
}

.note-picker-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx;
  border-bottom: 1px solid #f5f5f5;
}

.note-picker-item:last-child {
  border-bottom: none;
}

.note-picker-check {
  width: 30rpx;
  height: 30rpx;
  border-radius: 6rpx;
  border: 2rpx solid #94a3b8;
  background: #ffffff;
  margin-right: 10rpx;
  margin-top: 2rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.note-picker-check-on {
  border-color: #6c5ce7;
  background: #6c5ce7;
}

.note-picker-check-mark {
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
}

.note-picker-body {
  min-width: 0;
  flex: 1;
}

.note-picker-item-title {
  font-size: 24rpx;
  color: #1f2937;
}

.note-picker-item-preview {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attach-tag-bar {
  width: 100%;
  padding-bottom: 12rpx;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 12rpx;
}

.attach-tag-chip {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  padding: 8rpx 16rpx 8rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ede9fe, #e0e7ff);
  border: 1px solid #c4b5fd;
}

.attach-tag-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #5b21b6;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 12rpx;
}

.attach-tag-close {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #7c3aed;
  padding: 4rpx 8rpx;
}

.attach-tag-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #999999;
  line-height: 1.4;
}

.ai-input-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.ai-input {
  flex: 1;
  max-height: 160rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 1px solid #eeeeee;
  box-sizing: border-box;
  background-color: #ffffff;
  font-size: 26rpx;
}
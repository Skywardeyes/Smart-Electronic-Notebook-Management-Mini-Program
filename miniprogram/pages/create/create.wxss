.create-page {
  min-height: 100vh;
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  background: #f7f8fc;
}

.plus-wrapper {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.plus-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #6c5ce7;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(108, 92, 231, 0.4);
}

.plus-text {
  font-size: 80rpx;
  color: #ffffff;
  line-height: 1;
}

.plus-label {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #666666;
}

.actions {
  margin-top: 80rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.action-btn {
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 2.6;
}

.action-btn.primary {
  background: #6c5ce7;
  color: #ffffff;
}

.action-btn.secondary {
  background: #ffffff;
  color: #333333;
  border: 1rpx solid #e0e0e0;
}


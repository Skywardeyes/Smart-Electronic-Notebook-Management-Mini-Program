.pill-row {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.pill {
  min-width: 100rpx;
  text-align: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  border: 1px solid #ddd6fe;
  color: #4c1d95;
  background: #f8fafc;
}

.pill-active {
  border-color: #8b5cf6;
  background: #ede9fe;
  color: #5b21b6;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.desc {
  font-size: 24rpx;
  color: #888;
  margin: 10rpx 0;
}

.cache-intro {
  margin-bottom: 24rpx;
}

.cache-action-btn {
  width: 100%;
  margin-top: 8rpx;
}

.cache-action-btn-spaced {
  margin-top: 28rpx;
}

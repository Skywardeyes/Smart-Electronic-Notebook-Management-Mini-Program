<view class="home-page">
  <!-- 顶部导航栏 -->
  <view class="top-bar">
    <view class="top-left">
      <view class="avatar" bindtap="goProfile">Y</view>
      <view class="user-info">
        <view class="user-id-label">云友 ID</view>
        <view class="user-id">#A93F</view>
      </view>
      <view class="top-icons-left">
        <icon type="search" size="20" class="icon-btn"></icon>
        <icon type="info" size="20" class="icon-btn"></icon>
      </view>
    </view>
    <view class="top-right">
      <view class="app-title">智能云笔记</view>
      <view class="top-actions">
        <icon type="more" size="20" class="icon-btn"></icon>
        <view class="miniapp-btn"></view>
      </view>
    </view>
  </view>

  <!-- 标签栏 -->
  <view class="tabs">
    <view
      class="tab-item {{currentTab === 'latest' ? 'active' : ''}}"
      data-tab="latest"
      bindtap="onTabChange"
    >
      最新
    </view>
    <view
      class="tab-item {{currentTab === 'star' ? 'active' : ''}}"
      data-tab="star"
      bindtap="onTabChange"
    >
      收藏
    </view>
    <view
      class="tab-item {{currentTab === 'wechat' ? 'active' : ''}}"
      data-tab="wechat"
      bindtap="onTabChange"
    >
      微信文件
    </view>
  </view>

  <!-- 笔记列表 -->
  <view class="note-list">
    <block wx:for="{{notes}}" wx:key="id">
      <view class="note-item">
        <view class="note-icon">
          <text class="note-icon-text">文</text>
        </view>
        <view class="note-content">
          <view class="note-title">{{item.title}}</view>
          <view class="note-time">{{item.time}}</view>
        </view>
      </view>
    </block>
  </view>
</view>
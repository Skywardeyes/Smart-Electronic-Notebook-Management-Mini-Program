.hero-card {
  margin-top: 8rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: #111827;
}

.hero-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

.hero-actions {
  margin-top: 8rpx;
}

.hero-actions button {
  flex: 1;
}

.quick-actions {
  margin-top: 16rpx;
}

.quick-grid {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
}

.quick-item {
  flex: 1;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 6rpx 14rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.quick-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background-color: #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  margin-bottom: 12rpx;
  color: #4b5563;
}

.quick-icon-primary {
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: #ffffff;
}

.quick-text {
  font-size: 26rpx;
  color: #374151;
}

.home-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 40rpx;
  background-color: #ffffff;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.top-left {
  flex-direction: row;
  display: flex;
  align-items: center;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #a855f7, #6366f1);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-id-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.user-id {
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #4b5563;
}

.top-icons-left {
  display: flex;
  align-items: center;
  margin-left: 24rpx;
}

.top-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.app-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4c1d95;
}

.top-actions {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
}

.icon-btn {
  margin-left: 16rpx;
  color: #6b7280;
}

.miniapp-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  margin-left: 16rpx;
  background: radial-gradient(circle at 30% 30%, #bfdbfe, #4f46e5);
}

.tabs {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #6b7280;
  position: relative;
}

.tab-item.active {
  color: #4f46e5;
  font-weight: 600;
}

.tab-item.active::after {
  content: "";
  position: absolute;
  left: 25%;
  right: 25%;
  bottom: -2rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #8b5cf6, #3b82f6);
}

.note-list {
  margin-top: 8rpx;
}

.note-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid #f3f4f6;
}

.note-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #a855f7, #6366f1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.note-icon-text {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 600;
}

.note-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.note-title {
  font-size: 28rpx;
  color: #111827;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.note-time {
  font-size: 24rpx;
  color: #9ca3af;
}

.home-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 140rpx;
  background-color: #ffffff;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.top-left {
  flex-direction: row;
  display: flex;
  align-items: center;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #a855f7, #6366f1);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-id-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.user-id {
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #4b5563;
}

.top-icons-left {
  display: flex;
  align-items: center;
  margin-left: 24rpx;
}

.top-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.app-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4c1d95;
}

.top-actions {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
}

.icon-btn {
  margin-left: 16rpx;
  color: #6b7280;
}

.miniapp-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  margin-left: 16rpx;
  background: radial-gradient(circle at 30% 30%, #bfdbfe, #4f46e5);
}

/* —— 原文件夹页样式 —— */
.home-actions-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.search-box {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.search-icon {
  margin-right: 12rpx;
  font-size: 26rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-pill {
  display: inline-block;
  padding: 10rpx 22rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background-color: #f0f0f0;
  font-size: 24rpx;
  color: #666666;
}

.category-pill-active {
  background: linear-gradient(135deg, #a855f7, #6366f1);
  color: #ffffff;
}

.section-notes {
  margin-bottom: 24rpx;
}

.note-card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.note-card-main {
  flex: 1;
  min-width: 0;
  min-height: 80rpx;
}

.note-card-main-hover {
  background-color: rgba(129, 140, 248, 0.08);
}

.note-card-menu {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  min-width: 88rpx;
  flex-shrink: 0;
  min-height: 88rpx;
  margin: -8rpx -12rpx -8rpx 0;
  padding: 8rpx 12rpx;
  box-sizing: border-box;
  background: transparent;
  border-radius: 12rpx;
}

.note-card-menu-hover {
  background-color: rgba(129, 140, 248, 0.12);
}

.menu-dots {
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
  letter-spacing: 2rpx;
  pointer-events: none;
}

.note-title-row {
  display: flex;
  align-items: center;
}

.note-type-icon {
  margin-right: 8rpx;
}

.note-card .note-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.note-card .note-meta {
  font-size: 24rpx;
  color: #999999;
}

.note-snippet {
  font-size: 26rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-top: 8rpx;
}

.empty-state {
  margin-top: 24rpx;
}

.empty-title {
  text-align: center;
  font-size: 30rpx;
  margin-bottom: 8rpx;
}

.empty-desc {
  text-align: center;
  font-size: 26rpx;
  color: #999999;
}
